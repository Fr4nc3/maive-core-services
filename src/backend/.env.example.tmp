# =============================================================================
# MAIVE Backend — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.

# --- Application ---
APP_NAME=maive-backend
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000

# --- Azure Cosmos DB ---
COSMOS_ENDPOINT=https://<your-account>.documents.azure.com:443/
COSMOS_KEY=<your-primary-key>
COSMOS_DATABASE=maive

# --- Azure Identity (for managed identity / service principal) ---
# AZURE_CLIENT_ID=
# AZURE_TENANT_ID=
# AZURE_CLIENT_SECRET=

# --- CORS ---
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Logging ---
LOG_LEVEL=INFO

# =============================================================================
# LLM Provider — choose ONE of the two modes below
# =============================================================================
# Default is "ollama" for local development. Switch to "azure" for production
# data collection. Per DEC-004, agents never import a provider class directly;
# this single env var controls which backend the LLMProvider abstraction uses.
LLM_PROVIDER=ollama   # "ollama" | "azure"

# --- Mode A: Ollama (local development) ---
# Run Ollama locally: https://ollama.com  (default port 11434)
# Pull the models once:
#   ollama pull llama3
#   ollama pull nomic-embed-text
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=llama3
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# --- Mode B: Azure AI Foundry / Azure OpenAI (production) ---
# Required when LLM_PROVIDER=azure. Leave blank when using Ollama.
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_KEY=
AZURE_OPENAI_CHAT_DEPLOYMENT=
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=2024-12-01-preview
