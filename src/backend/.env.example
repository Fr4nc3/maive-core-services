# =============================================================================
# MAIVE Backend — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.

# --- Application ---
APP_NAME=maive-backend
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000

# --- Azure Cosmos DB ---
COSMOS_ENDPOINT=https://<your-account>.documents.azure.com:443/
COSMOS_KEY=<your-primary-key>
COSMOS_DATABASE=maive

# --- Azure Identity (for managed identity / service principal) ---
# AZURE_CLIENT_ID=
# AZURE_TENANT_ID=
# AZURE_CLIENT_SECRET=

# --- CORS ---
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Logging ---
LOG_LEVEL=INFO
